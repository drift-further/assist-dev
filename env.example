# Claude Assist — Environment Configuration
# Copy to .env and customize. All values have sensible defaults.

# Port to listen on (default: 8089)
# ASSIST_PORT=8089

# Root directory containing your projects (default: ~/projects)
# ASSIST_PROJECTS_DIR=/home/youruser/projects

# Path to the Claude skills directory (default: ~/.claude/skills)
# ASSIST_SKILLS_DIR=/home/youruser/.claude/skills

# Path to the container launch script for Automate Run.
# Defaults to docker/claude-mount.sh in the assist directory.
# Only override if you have a custom mount script elsewhere.
# ASSIST_MOUNT_SCRIPT=/path/to/claude-mount.sh

# CLI proxy — expose a host CLI tool inside Assist-launched containers.
# Containers get a wrapper at /usr/local/bin/<container_command> that POSTs
# to /api/cli-proxy on the host; the host then runs ASSIST_CLI_BIN with the
# forwarded args. Pair this with cli_proxy.container_command in
# container_config.json (the in-container name) and rebuild the image.
# ASSIST_CLI_BIN=/path/to/your-cli                              # absolute host path
# ASSIST_CLI_DIR=/path/to/your-project                          # cwd for the host CLI
# ASSIST_CLI_ALLOWED=backup,health,docker,ssl                   # comma-separated allowlist; empty = allow all

# Command to run when creating a new tmux session for a project
# ASSIST_SESSION_INIT_CMD=

# Database connection for session history (optional, degrades gracefully).
# Session history requires a PostgreSQL database with a sessions table.
# Also requires: pip install psycopg2-binary
# Without this, the session history feature returns empty results.
# ASSIST_DB_NAME=claude_archives
# ASSIST_DB_HOST=localhost

# X11 display for clipboard (xclip) and key-send (xdotool) operations.
# Default is :0 (standard desktops). VNC/Xvfb setups typically use :1.
# Headless servers without an X server will have clipboard features disabled.
# DISPLAY=:0
