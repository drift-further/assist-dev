{
  "id": "go",
  "name": "Go SDK",
  "builtin": true,
  "archive": null,
  "install": [
    "curl -fsSL https://go.dev/dl/go1.22.0.linux-amd64.tar.gz | tar -C /usr/local -xz",
    "mkdir -p /home/developer/go"
  ],
  "env": {"GOPATH": "/home/developer/go", "GOROOT": "/usr/local/go"},
  "path_add": "/usr/local/go/bin:/home/developer/go/bin",
  "enabled": false
}
